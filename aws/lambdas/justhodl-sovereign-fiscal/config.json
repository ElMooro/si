{
  "function_name": "justhodl-sovereign-fiscal",
  "region": "us-east-1",
  "runtime": "python3.12",
  "handler": "lambda_function.lambda_handler",
  "memory": 512,
  "timeout": 240,
  "architectures": ["x86_64"],
  "role": "arn:aws:iam::857687956942:role/lambda-execution-role",
  "description": "Foreign demand (TIC) + fiscal (MTS deficit/receipts/outlays) + debt service (avg interest, total debt). Output data/sovereign-fiscal.json.",
  "schedule": {"rule_name": "sovereign-fiscal-daily", "cron": "cron(10 7 * * ? *)", "description": "TIC + MTS + debt-service daily 07:10 UTC"}
}
