{
  "function_name": "justhodl-api-keys-admin",
  "region": "us-east-1",
  "runtime": "python3.12",
  "handler": "lambda_function.lambda_handler",
  "memory_size": 256,
  "timeout": 30,
  "architectures": ["x86_64"],
  "role": "arn:aws:iam::857687956942:role/lambda-execution-role",
  "environment_keys": [
    "JUSTHODL_API_KEYS_TABLE",
    "ADMIN_TOKEN_SSM"
  ],
  "layers": [],
  "reserved_concurrency": 2,
  "function_url": "to-be-created",
  "eventbridge_rules": [],
  "description": "Admin Lambda for managing Public API keys: create, revoke, list, rotate. Protected by SSM admin token. Backed by DynamoDB justhodl-api-keys table."
}
