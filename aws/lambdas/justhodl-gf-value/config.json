{
  "runtime": "python3.12",
  "memory": 1536,
  "timeout": 900,
  "handler": "lambda_function.lambda_handler",
  "role_arn": "arn:aws:iam::857687956942:role/lambda-execution-role",
  "description": "GuruFocus-style Composite Fair Value: per-ticker DCF+EV/EBIT+Graham blend on S&P 500. Margin-of-safety ratings. Damodaran 2002 + Greenblatt 2010 + Graham 1949. Daily 22:00 UTC.",
  "inherit_env": [
    {"from_function": "justhodl-earnings-quality", "keys": ["FMP_KEY"]},
    {"from_function": "justhodl-vol-surface", "keys": ["TELEGRAM_TOKEN", "TELEGRAM_CHAT_ID"]}
  ],
  "env": {
    "S3_BUCKET": "justhodl-dashboard-live"
  },
  "eventbridge_scheduler": {
    "schedule_name": "justhodl-gf-value-daily",
    "cron": "cron(0 22 * * ? *)",
    "timezone": "UTC",
    "role_arn": "arn:aws:iam::857687956942:role/justhodl-scheduler-role",
    "description": "GF Value Composite Fair Value daily 22:00 UTC"
  }
}
