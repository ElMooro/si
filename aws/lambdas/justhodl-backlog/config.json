{
  "function_name": "justhodl-backlog",
  "region": "us-east-1",
  "runtime": "python3.12",
  "handler": "lambda_function.lambda_handler",
  "timeout": 300,
  "memory": 512,
  "architectures": ["x86_64"],
  "role": "arn:aws:iam::857687956942:role/lambda-execution-role",
  "description": "Structured backlog/RPO/deferred-revenue signal from free SEC XBRL",
  "environment_keys": ["FMP_KEY"],
  "schedule": { "expression": "cron(30 11 * * ? *)", "name": "justhodl-backlog-daily", "description": "Daily 11:30 UTC backlog/RPO extraction" }
}
