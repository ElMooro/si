{
  "runtime": "python3.12",
  "memory": 512,
  "timeout": 180,
  "handler": "lambda_function.lambda_handler",
  "role_arn": "arn:aws:iam::857687956942:role/lambda-execution-role",
  "description": "Sentiment Extreme Composite (rebuilt 2026-05-21 v2.0.0). 5-source FRED z-score: VIXCLS+VXNCLS+USEPUINDXD+STLFSI4+UMCSENT. PANIC_RICH long SPY/QQQ/IWM, EUPHORIA_RICH short. Baker-Wurgler 2006. ~58-62%/+4-7%/4-8wk. Daily 21:15 UTC.",
  "inherit_env": [
    {"from_function": "justhodl-cross-asset-rv", "keys": ["FRED_KEY"]},
    {"from_function": "justhodl-vol-surface", "keys": ["TELEGRAM_TOKEN", "TELEGRAM_CHAT_ID"]}
  ],
  "env": {
    "S3_BUCKET": "justhodl-dashboard-live"
  },
  "eventbridge_scheduler": {
    "schedule_name": "justhodl-put-call-extreme-daily",
    "cron": "cron(15 21 * * ? *)",
    "timezone": "UTC",
    "role_arn": "arn:aws:iam::857687956942:role/justhodl-scheduler-role",
    "description": "Sentiment Extreme Composite daily 21:15 UTC"
  }
}
