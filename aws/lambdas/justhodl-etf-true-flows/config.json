{
  "function_name": "justhodl-etf-true-flows",
  "region": "us-east-1",
  "runtime": "python3.12",
  "handler": "lambda_function.lambda_handler",
  "timeout": 240,
  "memory": 512,
  "architectures": ["x86_64"],
  "role": "arn:aws:iam::857687956942:role/lambda-execution-role",
  "description": "True ETF net flows via shares-outstanding deltas x price",
  "environment_keys": ["FMP_KEY"],
  "schedule": { "expression": "cron(45 15 * * ? *)", "name": "justhodl-etf-true-flows-daily", "description": "Daily 15:45 UTC true ETF flows" }
}
