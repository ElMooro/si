{
  "name": "justhodl-onchain-ratios",
  "function_name": "justhodl-onchain-ratios",
  "region": "us-east-1",
  "runtime": "python3.12",
  "handler": "lambda_function.lambda_handler",
  "memory_size": 768,
  "memory_mb": 768,
  "timeout": 300,
  "timeout_s": 300,
  "architectures": [
    "x86_64"
  ],
  "role": "arn:aws:iam::857687956942:role/lambda-execution-role",
  "environment_keys": [
    "S3_BUCKET"
  ],
  "layers": [],
  "reserved_concurrency": 1,
  "function_url": {
    "auth_type": "NONE",
    "cors": {
      "AllowCredentials": false,
      "AllowHeaders": [
        "content-type"
      ],
      "AllowMethods": [
        "*"
      ],
      "AllowOrigins": [
        "*"
      ],
      "MaxAge": 86400
    }
  },
  "eventbridge_rules": [
    "justhodl-onchain-ratios-6h"
  ],
  "description": "BTC + ETH on-chain ratios (Glassnode-equivalent): MVRV, NVT, hash rate, ETH gas, ETH supply growth. CoinMetrics + mempool.space + etherscan."
}
