{
  "function_name": "justhodl-cross-asset-flow-state",
  "region": "us-east-1",
  "runtime": "python3.12",
  "handler": "lambda_function.lambda_handler",
  "timeout": 60,
  "memory": 256,
  "architectures": ["x86_64"],
  "role": "arn:aws:iam::857687956942:role/lambda-execution-role",
  "description": "Unified cross-asset flow synthesizer -> data/cross-asset-flow-state.json (one feed for allocator/hedge-planner/MI)",
  "schedule": {"expression": "rate(2 hours)", "name": "justhodl-cross-asset-flow-state-2h", "description": "Synthesize cross-asset flow every 2h"}
}
