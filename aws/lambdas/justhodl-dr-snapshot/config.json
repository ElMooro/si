  "env": {
    "S3_BUCKET": "justhodl-dashboard-live",
    "DR_BUCKET": "justhodl-dashboard-live-dr",
    "MAX_WORKERS": "15",
    "TELEGRAM_BOT_TOKEN": "8679881066:AAHTE6TAhDqs0FuUelTL6Ppt1x8ihis1aGs",
    "TELEGRAM_CHAT_ID": "8678089260"
  },
  "schedule": {
    "rule_name": "dr-snapshot-daily",
    "cron": "cron(0 6 * * ? *)",
    "description": "Daily 06 UTC — complete platform DR snapshot"
  }
}
