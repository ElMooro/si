{
  "function_name": "justhodl-catalyst-calendar",
  "region": "us-east-1",
  "runtime": "python3.12",
  "handler": "lambda_function.lambda_handler",
  "timeout": 120,
  "memory": 512,
  "architectures": ["x86_64"],
  "role": "arn:aws:iam::857687956942:role/lambda-execution-role",
  "description": "FDA PDUFA + US government contract award catalysts (free early-detection feeds)",
  "environment_keys": ["FMP_KEY"],
  "schedule": { "expression": "cron(0 12 * * ? *)", "name": "justhodl-catalyst-calendar-daily", "description": "Daily 12:00 UTC catalyst calendar" }
}
