{
    "runtime": "python3.12",
    "memory": 512,
    "timeout": 240,
    "handler": "lambda_function.lambda_handler",
    "role_arn": "arn:aws:iam::857687956942:role/lambda-execution-role",
    "description": "Breadth divergence detector. SPY 20d return vs 11 SPDR sector breadth + 20d slope + IWM-SPY lag. BEAR_DIV (narrow leadership) or BULL_DIV (broadening). Magee 1950s, Whaley 2009. Daily 22 UTC.",
    "inherit_env": true,
    "env": {
        "S3_BUCKET": "justhodl-dashboard-live"
    },
    "eventbridge_scheduler": {
        "schedule_name": "justhodl-breadth-divergence-daily",
        "cron": "cron(0 22 * * ? *)",
        "timezone": "UTC",
        "role_arn": "arn:aws:iam::857687956942:role/justhodl-scheduler-role",
        "description": "Breadth divergence daily 22 UTC"
    }
}
