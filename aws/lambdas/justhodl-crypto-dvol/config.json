{
  "function_name": "justhodl-crypto-dvol",
  "region": "us-east-1",
  "runtime": "python3.12",
  "handler": "lambda_function.lambda_handler",
  "memory": 256,
  "timeout": 60,
  "architectures": ["x86_64"],
  "role": "arn:aws:iam::857687956942:role/lambda-execution-role",
  "description": "Crypto implied-volatility complex (DVOL) — BTC/ETH option-implied vol index, 1y percentile, regime & trend from Deribit. The missing crypto-VIX for the cycle clock. data/crypto-dvol.json.",
  "environment": {"S3_BUCKET": "justhodl-dashboard-live"},
  "schedule": {
    "rule_name": "justhodl-crypto-dvol-hourly",
    "cron": "cron(15 * * * ? *)",
    "description": "Crypto DVOL hourly at :15"
  }
}
