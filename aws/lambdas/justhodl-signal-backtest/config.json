{
  "function_name": "justhodl-signal-backtest",
  "region": "us-east-1",
  "runtime": "python3.12",
  "handler": "lambda_function.lambda_handler",
  "timeout": 300,
  "memory": 512,
  "architectures": ["x86_64"],
  "role": "arn:aws:iam::857687956942:role/lambda-execution-role",
  "description": "Forward-return backtest of signals by verdict/compounder/cap/revision — proves what works",
  "environment_keys": ["FMP_KEY"],
  "schedule": { "expression": "cron(0 16 * * ? *)", "name": "justhodl-signal-backtest-daily", "description": "Daily 16:00 UTC signal backtest" }
}
