{
  "name": "justhodl-gdelt-sentiment",
  "function_name": "justhodl-gdelt-sentiment",
  "region": "us-east-1",
  "runtime": "python3.12",
  "handler": "lambda_function.lambda_handler",
  "memory_size": 1024,
  "memory_mb": 1024,
  "timeout": 300,
  "timeout_s": 300,
  "architectures": [
    "x86_64"
  ],
  "role": "arn:aws:iam::857687956942:role/lambda-execution-role",
  "environment_keys": [
    "S3_BUCKET"
  ],
  "layers": [],
  "reserved_concurrency": 1,
  "function_url": {
    "auth_type": "NONE",
    "cors": {
      "AllowCredentials": false,
      "AllowHeaders": [
        "content-type"
      ],
      "AllowMethods": [
        "*"
      ],
      "AllowOrigins": [
        "*"
      ],
      "MaxAge": 86400
    }
  },
  "eventbridge_rules": [
    "justhodl-gdelt-sentiment-30min"
  ],
  "description": "GDELT 2.0 global news + geopolitical sentiment. Pulls latest 15-min GKG batch, filters financial themes, computes per-asset sentiment."
}
