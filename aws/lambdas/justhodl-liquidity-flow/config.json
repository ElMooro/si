{
  "name": "justhodl-liquidity-flow",
  "function_name": "justhodl-liquidity-flow",
  "region": "us-east-1",
  "runtime": "python3.12",
  "handler": "lambda_function.lambda_handler",
  "memory_mb": 256,
  "timeout": 120,
  "timeout_s": 120,
  "architectures": [
    "x86_64"
  ],
  "role": "arn:aws:iam::857687956942:role/lambda-execution-role",
  "environment_keys": [
    "S3_BUCKET",
    "S3_KEY",
    "FRED_KEY"
  ],
  "layers": [],
  "reserved_concurrency": 1,
  "function_url": null,
  "eventbridge_rules": [
    "justhodl-liquidity-flow-daily"
  ],
  "description": "TGA + RRP + WALCL liquidity tracker. Computes net_liquidity = WALCL - TGA - RRP, deltas at 1d/1w/1m/3m, regime classification (expanding/stable/draining).",
  "memory": 256
}
