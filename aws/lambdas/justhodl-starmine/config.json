{
  "runtime": "python3.12",
  "memory": 1536,
  "timeout": 900,
  "handler": "lambda_function.lambda_handler",
  "role_arn": "arn:aws:iam::857687956942:role/lambda-execution-role",
  "description": "StarMine Analyst Skill Ranking (Refinitiv gap-closer): top-150 SP500 ranked by tier-weighted rating-revision momentum + PT drift + earnings-surprise persistence. Daily 23:30 UTC.",
  "inherit_env": [
    {"from_function": "justhodl-earnings-quality", "keys": ["FMP_KEY"]},
    {"from_function": "justhodl-vol-surface", "keys": ["TELEGRAM_TOKEN", "TELEGRAM_CHAT_ID"]}
  ],
  "env": {
    "S3_BUCKET": "justhodl-dashboard-live"
  },
  "eventbridge_scheduler": {
    "schedule_name": "justhodl-starmine-daily",
    "cron": "cron(30 23 * * ? *)",
    "timezone": "UTC",
    "role_arn": "arn:aws:iam::857687956942:role/justhodl-scheduler-role",
    "description": "StarMine Analyst Skill daily 23:30 UTC"
  }
}
