{
  "function_name": "justhodl-fleet-error-monitor",
  "region": "us-east-1",
  "runtime": "python3.12",
  "handler": "lambda_function.lambda_handler",
  "memory": 512,
  "timeout": 180,
  "architectures": ["x86_64"],
  "role": "arn:aws:iam::857687956942:role/lambda-execution-role",
  "description": "AUDIT P2 — fleet-wide error rate + DLQ monitor; alerts via Telegram + SNS",
  "env": {
    "S3_BUCKET": "justhodl-dashboard-live",
    "SNS_ARN": "arn:aws:sns:us-east-1:857687956942:justhodl-fleet-alerts",
    "DLQ_NAME": "justhodl-dlq-default",
    "ERROR_RATE_THRESHOLD": "5",
    "MIN_INVOCATIONS": "5",
    "LOOKBACK_MINUTES": "15",
    "DLQ_DEPTH_THRESHOLD": "1",
    "DEDUPE_WINDOW_MINUTES": "60",
    "TELEGRAM_BOT_TOKEN": "8679881066:AAHTE6TAhDqs0FuUelTL6Ppt1x8ihis1aGs",
    "TELEGRAM_CHAT_ID": "8678089260"
  },
  "schedule": {
    "rule_name": "fleet-error-monitor-5min",
    "cron": "rate(5 minutes)",
    "description": "AUDIT P2 — scan fleet error rates + DLQ depth every 5 minutes"
  }
}
