{
  "function_name": "justhodl-portfolio-risk",
  "region": "us-east-1",
  "runtime": "python3.12",
  "handler": "lambda_function.lambda_handler",
  "memory": 1024,
  "timeout": 300,
  "architectures": ["x86_64"],
  "role": "arn:aws:iam::857687956942:role/lambda-execution-role",
  "description": "Portfolio risk engine (#10). VAR, beta, correlations, sector concentration, historical scenarios, stop-loss + concentration + cluster alerts.",
  "environment": {},
  "inherit_env": [
    {"from_function": "justhodl-options-flow-scanner", "keys": ["POLY_KEY"]},
    {"from_function": "justhodl-screener-alerts", "keys": ["TELEGRAM_TOKEN", "TELEGRAM_CHAT_ID"]}
  ],
  "schedule": {
    "rule_name": "justhodl-portfolio-risk-hourly",
    "cron": "cron(43 * * * ? *)",
    "description": "Every hour at :43 - 3 min after portfolio-snapshot (:40) so snapshot is fresh"
  }
}
