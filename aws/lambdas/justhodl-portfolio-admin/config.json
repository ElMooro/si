{
  "function_name": "justhodl-portfolio-admin",
  "region": "us-east-1",
  "runtime": "python3.12",
  "handler": "lambda_function.lambda_handler",
  "memory": 256,
  "timeout": 30,
  "architectures": ["x86_64"],
  "role": "arn:aws:iam::857687956942:role/lambda-execution-role",
  "description": "Portfolio CRUD (#9). Dual-mode: direct invoke (ops) un-gated; Function URL gated by x-justhodl-token (SSM /justhodl/portfolio-admin/token) + Origin allowlist. Mutations auto-trigger portfolio-snapshot.",
  "environment": {},
  "function_url": {
    "auth_type": "NONE",
    "cors": {
      "AllowCredentials": false,
      "AllowHeaders": ["content-type", "x-justhodl-token"],
      "AllowMethods": ["POST", "OPTIONS"],
      "AllowOrigins": ["https://justhodl.ai", "https://www.justhodl.ai"],
      "MaxAge": 300
    }
  }
}
