{
  "runtime": "python3.12",
  "memory": 512,
  "timeout": 180,
  "handler": "lambda_function.lambda_handler",
  "role_arn": "arn:aws:iam::857687956942:role/lambda-execution-role",
  "description": "Cross-engine AI synthesis. Reads 12 engines, calls Claude haiku-4-5, writes ai-website-synthesis.json. Hourly cron at :25.",
  "inherit_env": {
    "from_function": "justhodl-ai-chat",
    "keys": ["ANTHROPIC_API_KEY"]
  },
  "eventbridge_scheduler": {
    "schedule_name": "justhodl-ai-website-synthesis-hourly",
    "cron": "cron(25 * * * ? *)",
    "timezone": "UTC",
    "role_arn": "arn:aws:iam::857687956942:role/justhodl-scheduler-role",
    "description": "Cross-engine AI synthesis hourly"
  }
}
