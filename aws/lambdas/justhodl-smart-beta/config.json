{
  "runtime": "python3.12",
  "memory": 1024,
  "timeout": 600,
  "handler": "lambda_function.lambda_handler",
  "role_arn": "arn:aws:iam::857687956942:role/lambda-execution-role",
  "description": "Refinitiv/MSCI Smart Beta Composite: 4-factor (Value+Quality+Momentum+LowVol) equal-weight percentile rank. Identifies market factor regime + diversified leaders. Daily 00:15 UTC.",
  "inherit_env": [
    {"from_function": "justhodl-starmine", "keys": ["FMP_KEY"]},
    {"from_function": "justhodl-vol-surface", "keys": ["TELEGRAM_TOKEN", "TELEGRAM_CHAT_ID"]}
  ],
  "env": {
    "S3_BUCKET": "justhodl-dashboard-live"
  },
  "eventbridge_scheduler": {
    "schedule_name": "justhodl-smart-beta-daily",
    "cron": "cron(15 0 * * ? *)",
    "timezone": "UTC",
    "role_arn": "arn:aws:iam::857687956942:role/justhodl-scheduler-role",
    "description": "Smart Beta 4-factor daily 00:15 UTC"
  }
}
