{
  "name": "justhodl-price-redundancy",
  "function_name": "justhodl-price-redundancy",
  "region": "us-east-1",
  "runtime": "python3.12",
  "handler": "lambda_function.lambda_handler",
  "memory_mb": 768,
  "timeout": 300,
  "timeout_s": 300,
  "architectures": [
    "x86_64"
  ],
  "role": "arn:aws:iam::857687956942:role/lambda-execution-role",
  "environment_keys": [
    "S3_BUCKET"
  ],
  "layers": [],
  "reserved_concurrency": 1,
  "function_url": {
    "auth_type": "NONE",
    "cors": {
      "AllowCredentials": false,
      "AllowHeaders": [
        "content-type"
      ],
      "AllowMethods": [
        "*"
      ],
      "AllowOrigins": [
        "*"
      ],
      "MaxAge": 86400
    }
  },
  "eventbridge_rules": [
    "justhodl-price-redundancy-15min"
  ],
  "description": "Stooq + Yahoo Finance free price feed redundancy. Fallback for FMP rate limits. 23 core tickers including BTC/ETH/VIX/DXY/TNX.",
  "memory": 768
}
