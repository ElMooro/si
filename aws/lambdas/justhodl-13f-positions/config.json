  "architectures": ["x86_64"],
  "role": "arn:aws:iam::857687956942:role/lambda-execution-role",
  "environment_keys": [
    "S3_BUCKET",
    "S3_KEY",
    "S3_CACHE_PREFIX",
    "S3_FILINGS_KEY",
    "USER_AGENT",
    "FMP_KEY",
    "MAX_PARALLEL"
  ],
  "layers": [],
  "reserved_concurrency": 1,
  "function_url": null,
  "eventbridge_rules": ["justhodl-13f-positions-6h"],
