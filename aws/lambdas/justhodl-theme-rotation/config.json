{
  "function_name": "justhodl-theme-rotation",
  "region": "us-east-1",
  "runtime": "python3.12",
  "handler": "lambda_function.lambda_handler",
  "memory": 512,
  "timeout": 240,
  "architectures": ["x86_64"],
  "role": "arn:aws:iam::857687956942:role/lambda-execution-role",
  "description": "Cross-theme rotation (RRG): relative strength + momentum across 40+ themes -> IMPROVING/LEADING/WEAKENING/LAGGING quadrants; rotating-in theme seeds feed the ledger.",
  "schedule": { "rule_name": "theme-rotation-daily", "cron": "cron(30 13 * * ? *)", "description": "Daily theme rotation 13:30 UTC" }
}
