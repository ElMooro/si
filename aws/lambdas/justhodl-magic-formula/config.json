{
  "runtime": "python3.12",
  "memory": 1536,
  "timeout": 900,
  "handler": "lambda_function.lambda_handler",
  "role_arn": "arn:aws:iam::857687956942:role/lambda-execution-role",
  "description": "Greenblatt Magic Formula Screener: rank S&P 500 (ex-fin/utils/REITs) by Earnings Yield + ROIC. GuruFocus signature. Greenblatt 2010 30.8% CAGR backtest. Daily 22:45 UTC.",
  "inherit_env": [
    {"from_function": "justhodl-earnings-quality", "keys": ["FMP_KEY"]},
    {"from_function": "justhodl-vol-surface", "keys": ["TELEGRAM_TOKEN", "TELEGRAM_CHAT_ID"]}
  ],
  "env": {
    "S3_BUCKET": "justhodl-dashboard-live"
  },
  "eventbridge_scheduler": {
    "schedule_name": "justhodl-magic-formula-daily",
    "cron": "cron(45 22 * * ? *)",
    "timezone": "UTC",
    "role_arn": "arn:aws:iam::857687956942:role/justhodl-scheduler-role",
    "description": "Magic Formula Screener daily 22:45 UTC"
  }
}
